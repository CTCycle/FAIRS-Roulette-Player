{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FAIRS Desktop",
  "version": "2.4.0",
  "identifier": "com.fairs.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "about:blank"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FAIRS Desktop",
        "url": "about:blank",
        "width": 1440,
        "height": 920,
        "center": true,
        "resizable": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "r/server/pyproject.toml": "app/server/pyproject.toml",
      "r/server/uv.lock": "app/server/uv.lock",
      "r/server": "app/server",
      "r/scripts": "app/scripts",
      "r/settings": "settings",
      "r/client/dist": "app/client/dist",
      "r/resources/checkpoints": "app/resources/checkpoints",
      "r/resources/database.db": "app/resources/database.db",
      "r/resources/logs": "app/resources/logs",
      "r/runtimes/nodejs": "runtimes/nodejs",
      "r/runtimes/python": "runtimes/python",
      "r/runtimes/uv": "runtimes/uv"
    }
  }
}
